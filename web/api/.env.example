# App URL (your Fly.io deployment)
APP_URL=https://your-app-name.fly.dev

# --- Auth: Option A (Single-user, simplest) ---
# Run `python3 scripts/x_api_auth.py --client-id YOUR_ID` locally,
# then copy the tokens from ~/.config/x-bookmarks/tokens.json
X_API_BEARER_TOKEN=your_access_token_here
X_API_REFRESH_TOKEN=your_refresh_token_here

# --- Auth: Option B (Full OAuth, multi-user capable) ---
# Create an X Developer app at https://developer.x.com
# Set callback URL to: ${APP_URL}/auth/callback
X_CLIENT_ID=your_x_client_id
X_CLIENT_SECRET=your_x_client_secret
